#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>
#include <unistd.h>

#define N          5         
#define EAT_TIMES  3         

pthread_mutex_t fork_mutex[N];   
void *philosopher(void *arg)
{
    int id    = *((int *) arg);
    int left  = id;            /* left  fork index */
    int right = (id + 1) % N;  /* right fork index */

    for (int meal = 1; meal <= EAT_TIMES; meal++) {
        printf("Philosopher %d is THINKING  (meal %d/%d)\n", id+1, meal, EAT_TIMES);
        usleep((rand() % 300 + 100) * 1000);  
        
        if (id % 2 == 0) {
            pthread_mutex_lock(&fork_mutex[left]);
            printf("Philosopher %d picked up LEFT  fork %d\n", id+1, left+1);
            pthread_mutex_lock(&fork_mutex[right]);
            printf("Philosopher %d picked up RIGHT fork %d\n", id+1, right+1);
        } else {
            pthread_mutex_lock(&fork_mutex[right]);
            printf("Philosopher %d picked up RIGHT fork %d\n", id+1, right+1);
            pthread_mutex_lock(&fork_mutex[left]);
            printf("Philosopher %d picked up LEFT  fork %d\n", id+1, left+1);
        }
        printf("*** Philosopher %d is EATING   (meal %d/%d) ***\n", id+1, meal, EAT_TIMES);
        usleep((rand() % 300 + 100) * 1000);   /* 100–400 ms */

        pthread_mutex_unlock(&fork_mutex[left]);
        pthread_mutex_unlock(&fork_mutex[right]);
        printf("Philosopher %d put down BOTH forks.\n", id+1);
    }

    printf("Philosopher %d is DONE (ate %d times).\n", id+1, EAT_TIMES);
    return NULL;
}
int main(void)
{
    pthread_t threads[N];
    int       ids[N];

    srand(42);
    
    for (int i = 0; i < N; i++)
        pthread_mutex_init(&fork_mutex[i], NULL);
    printf("=== Dining Philosophers (N=%d, meals=%d) ===\n\n", N, EAT_TIMES);

    for (int i = 0; i < N; i++) {
        ids[i] = i;
        pthread_create(&threads[i], NULL, philosopher, &ids[i]);
    }
    for (int i = 0; i < N; i++)
        pthread_join(threads[i], NULL);
    for (int i = 0; i < N; i++)
        pthread_mutex_destroy(&fork_mutex[i]);

    printf("\nAll philosophers have finished dining. No deadlock occurred!\n");
    return 0;
}
