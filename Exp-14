#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_FILES      20
#define MAX_NAME_LEN   50

typedef struct {
    char name[MAX_NAME_LEN];
    int  size;           /* KB  */
    char owner[MAX_NAME_LEN];
} FileEntry;

FileEntry directory[MAX_FILES];
int       file_count = 0;

int  find_file(const char *name);
void create_file(const char *name, int size, const char *owner);
void delete_file(const char *name);
void search_file(const char *name);
void list_files(void);
void rename_file(const char *old_name, const char *new_name);

int find_file(const char *name)
{
    for (int i = 0; i < file_count; i++)
        if (strcmp(directory[i].name, name) == 0)
            return i;
    return -1;
}
void create_file(const char *name, int size, const char *owner)
{
    if (file_count >= MAX_FILES) {
        printf("  ERROR: Directory is full.\n");
        return;
    }
    if (find_file(name) != -1) {
        printf("  ERROR: File '%s' already exists.\n", name);
        return;
    }
    strncpy(directory[file_count].name,  name,  MAX_NAME_LEN - 1);
    strncpy(directory[file_count].owner, owner, MAX_NAME_LEN - 1);
    directory[file_count].size = size;
    file_count++;
    printf("  File '%s' created (size=%d KB, owner=%s).\n", name, size, owner);
}

void delete_file(const char *name)
{
    int idx = find_file(name);
    if (idx == -1) {
        printf("  ERROR: File '%s' not found.\n", name);
        return;
    }
    for (int i = idx; i < file_count - 1; i++)
        directory[i] = directory[i + 1];
    file_count--;
    printf("  File '%s' deleted.\n", name);
}
void search_file(const char *name)
{
    int idx = find_file(name);
    if (idx == -1)
        printf("  File '%s' NOT found in directory.\n", name);
    else
        printf("  File '%s' FOUND  |  Size: %d KB  |  Owner: %s\n",
               name, directory[idx].size, directory[idx].owner);
}
void list_files(void)
{
    if (file_count == 0) {
        printf("  [Directory is empty]\n");
        return;
    }
    printf("  %-5s %-20s %10s  %-15s\n", "No.", "File Name", "Size(KB)", "Owner");
    printf("  ---  --------------------  ----------  ---------------\n");
    for (int i = 0; i < file_count; i++)
        printf("  %-5d %-20s %10d  %-15s\n",
               i + 1, directory[i].name,
               directory[i].size, directory[i].owner);
}
void rename_file(const char *old_name, const char *new_name)
{
    int idx = find_file(old_name);
    if (idx == -1) {
        printf("  ERROR: File '%s' not found.\n", old_name);
        return;
    }
    if (find_file(new_name) != -1) {
        printf("  ERROR: Name '%s' is already taken.\n", new_name);
        return;
    }
    strncpy(directory[idx].name, new_name, MAX_NAME_LEN - 1);
    printf("  File '%s' renamed to '%s'.\n", old_name, new_name);
}
int main(void)
{
    printf("=== Single-Level Directory Simulation ===\n\n");

    printf("[1] Creating files:\n");
    create_file("resume.txt",    45,  "alice");
    create_file("photo.jpg",     2048,"bob");
    create_file("notes.txt",     12,  "alice");
    create_file("data.csv",      300, "charlie");
    create_file("program.c",     8,   "bob");

    printf("\n[2] Listing all files:\n");
    list_files();

    printf("\n[3] Searching files:\n");
    search_file("photo.jpg");
    search_file("missing.bin");

    printf("\n[4] Renaming 'notes.txt' to 'lecture_notes.txt':\n");
    rename_file("notes.txt", "lecture_notes.txt");

    printf("\n[5] Deleting 'data.csv':\n");
    delete_file("data.csv");

    printf("\n[6] Attempting to create duplicate 'resume.txt':\n");
    create_file("resume.txt", 10, "dave");

    printf("\n[7] Final directory listing:\n");
    list_files();

    return 0;
}
